# Domain configuration
# Set to your domain (e.g., fuiz.example.com) for automatic HTTPS via Caddy
# Set to localhost for local development (HTTP only)
FUIZ_DOMAIN=localhost

# Ports (only used when FUIZ_DOMAIN=localhost)
FUIZ_PORT=80
FUIZ_TLS_PORT=443

# Frontend environment variables
# These are injected at container startup
ORIGIN=https://localhost
PUBLIC_DISPLAY_PLAY_URL=localhost
PUBLIC_PLAY_URL=https://localhost
PUBLIC_BACKEND_URL=https://localhost/api
PUBLIC_WS_URL=wss://localhost/api
PUBLIC_CORKBOARD_URL=https://localhost/corkboard

# Game server CORS (JSON array of allowed origins, empty = permissive)
FUIZ_ALLOWED_ORIGINS=["https://localhost"]

# Corkboard CORS
CORKBOARD_ALLOWED_ORIGINS=["https://localhost"]

# AI configuration (optional)
# Uncomment and configure to enable AI-powered tag derivation for library quizzes
# Supports any OpenAI-compatible API (OpenAI, Ollama, OpenRouter, LiteLLM, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=
# AI_MODEL=gpt-4o-mini
